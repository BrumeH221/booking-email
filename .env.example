# Copy to .env.gemini or .env.groq and fill real values.

RUN_MODE=local

# Master switches
USE_LLM_API=true
USE_LOCAL_MODELS=false

# Provider
LLM_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# HuggingFace model names (only used when USE_LOCAL_MODELS=true)
INTENT_MODEL_NAME=facebook/bart-large-mnli
SENTIMENT_MODEL_NAME=cardiffnlp/twitter-roberta-base-sentiment-latest
EMBEDDING_MODEL_NAME=BAAI/bge-m3
SUMMARY_MODEL_NAME=

# Database
DB_BACKEND=sqlite
SQLITE_PATH=data/bookings.db

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BOOKINGS_TABLE=bookings
SUPABASE_PROCESSED_TABLE=processed_emails

# Google Sheets mirror
SHEETS_ENABLED=false
SHEETS_SPREADSHEET_ID=
SHEETS_WORKSHEET_NAME=Bookings
GOOGLE_SERVICE_ACCOUNT_PATH=service_account.json
GOOGLE_SERVICE_ACCOUNT_JSON=

# Gmail
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GMAIL_TOKEN_JSON=
GMAIL_CREDENTIALS_JSON=

# Business
BUSINESS_NAME=Booking Team
MANAGER_NOTIFY_EMAIL=
MAX_EMAILS_PER_RUN=20
DUPLICATE_SIMILARITY_THRESHOLD=0.92

# Gmail search query (NO subject filter — AI judges intent from body)
GMAIL_SEARCH_QUERY=is:unread -category:promotions -category:social -category:updates

# Cloud worker auth
WORKER_SHARED_SECRET=
